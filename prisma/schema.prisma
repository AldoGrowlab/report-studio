generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  founder
  user
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(user)
  createdAt    DateTime @default(now())

  reports Report[]
}

enum Platform {
  shopee
  tiktok
}

enum SectionStatus {
  draft
  active
}

model Section {
  id             String          @id @default(cuid())
  platform       Platform
  name           String
  narrativeOrder Int
  status         SectionStatus   @default(draft)
  kbAnalysis     String          @default("")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  metrics    SectionMetric[]
  uploads    Upload[]
  kbVersions KbVersion[]
  insights   Insight[]

  @@unique([platform, name])
}

enum MetricType {
  number
  currency
  percent
  ratio
}

model SectionMetric {
  id        String     @id @default(cuid())
  sectionId String
  key       String
  label     String
  type      MetricType @default(number)
  required  Boolean    @default(false)

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

model KbVersion {
  id        String   @id @default(cuid())
  sectionId String
  version   Int
  content   String
  createdAt DateTime @default(now())

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

enum ReportStatus {
  draft
  processing
  done
}

model Report {
  id           String       @id @default(cuid())
  reportPeriod String
  platforms    Platform[]
  status       ReportStatus @default(draft)
  createdById  String
  createdAt    DateTime     @default(now())

  createdBy   User         @relation(fields: [createdById], references: [id])
  uploads     Upload[]
  flags       Flag[]
  insights    Insight[]
  conclusions Conclusion[]
}

model Upload {
  id             String   @id @default(cuid())
  reportId       String
  reportPeriod   String
  platform       Platform
  sectionId      String
  imageUrl       String
  labelConfirmed Boolean  @default(false)
  createdAt      DateTime @default(now())

  report      Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)
  section     Section      @relation(fields: [sectionId], references: [id])
  extractions Extraction[]
}

enum ExtractionStatus {
  ok
  missing
  low_confidence
}

model Extraction {
  id                String           @id @default(cuid())
  uploadId          String
  key               String
  value             Float?
  rawText           String?
  confidence        Float            @default(0)
  status            ExtractionStatus @default(ok)
  // Tahap 5: true kalau user sudah konfirmasi/koreksi manual angka ini.
  // rawText & confidence asli TIDAK ditimpa (provenance OCR tetap utuh).
  manuallyConfirmed Boolean          @default(false)

  upload Upload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
}

// Tahap 6a — insight Analyst per (report, section). Generate ulang = replace (upsert).
// points  = poin-poin insight (target 6 lunak, atap keras 8 — dipotong saat parsing),
//           menggantikan paragraf tunggal (keputusan Jul 2026).
// numbers = snapshot kosakata angka singkat (valueText) yang dikirim ke model saat generate —
//           dipakai renderer (PPT & web) untuk mem-bold angka metrik secara DETERMINISTIK
//           via pencocokan substring, TANPA penanda markdown dari LLM.
// kbVersion = versi KbVersion yang dipakai saat generate (pelacakan per DESIGN §Sistem Flag).
model Insight {
  id        String   @id @default(cuid())
  reportId  String
  sectionId String
  points    String[]
  numbers   String[]
  kbVersion Int
  generator String // "claude" | "stub"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  report    Report            @relation(fields: [reportId], references: [id], onDelete: Cascade)
  section   Section           @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  revisions InsightRevision[]

  @@unique([reportId, sectionId])
}

// Tahap 7b — jejak revisi Validator atas satu insight: TIDAK ada perubahan diam-diam.
// Validator memberi INSTRUKSI koreksi (bukan menulis ulang); Analyst yang merevisi dengan
// bahan angka SAMA dari Extraction (angka tak boleh berubah). Maks 1 putaran per section
// per run; resolved=false = cek ulang masih menemukan masalah → ter-escalate (ada Flag).
// Generate ulang insight manual menghapus jejak lama (jejak menempel pada generasi itu).
model InsightRevision {
  id           String   @id @default(cuid())
  insightId    String
  pointsBefore String[]
  pointsAfter  String[]
  reason       String // inkonsistensi yang ditemukan Validator (kontradiksi/tone + uraian)
  instruction  String // instruksi koreksi Validator yang dieksekusi Analyst
  resolved     Boolean
  createdAt    DateTime @default(now())

  insight Insight @relation(fields: [insightId], references: [id], onDelete: Cascade)
}

// Tahap 7a — kesimpulan Validator per (report, platform). Generate ulang = replace (upsert).
// Tabel SENDIRI (bukan Insight + penanda): identitasnya beda — Insight unik per
// (report, section), kesimpulan unik per (report, platform) — dan query Insight lama
// tak perlu mengecualikan apa pun. Kesimpulan TIDAK pernah gabungan lintas-platform
// (DESIGN Prinsip #4 & §Validator & Kesimpulan).
// points/numbers = mekanisme sama dengan Insight: poin (target 6 lunak, atap keras 8) +
// kosakata angka singkat untuk bold deterministik — numbers = union Insight.numbers
// semua section platform ini saat generate.
model Conclusion {
  id        String   @id @default(cuid())
  reportId  String
  platform  Platform
  points    String[]
  numbers   String[]
  generator String // "claude" | "stub"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, platform])
}

// Tahap 7a — dua KB Validator (DESIGN §Validator & Kesimpulan), satu baris per platform:
// kbGeneral = KB general/merangkai; kbConclusion = KB kesimpulan. Diisi founder via
// /dashboard/validator-kb; kosong = sah (prompt memakai penilaian umum).
// Versioning à la KbVersion DITUNDA sampai sistem flag (7b/9) — lihat backlog DESIGN.
model ValidatorKb {
  id           String   @id @default(cuid())
  platform     Platform @unique
  kbGeneral    String   @default("")
  kbConclusion String   @default("")
  updatedAt    DateTime @updatedAt
}

enum FlagSeverity {
  info
  tinggi
}

model Flag {
  id        String       @id @default(cuid())
  reportId  String
  platform  Platform
  section   String
  type      String
  severity  FlagSeverity @default(info)
  note      String
  createdAt DateTime     @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
}