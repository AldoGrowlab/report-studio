generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  founder
  user
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(user)
  createdAt    DateTime @default(now())

  reports Report[]
}

enum Platform {
  shopee
  tiktok
}

enum SectionStatus {
  draft
  active
}

model Section {
  id                   String        @id @default(cuid())
  platform             Platform
  name                 String
  narrativeOrder       Int
  status               SectionStatus @default(draft)
  kbAnalysis           String        @default("")
  // Tahap 6b — opt-in founder: section ini membandingkan performa antar bulan.
  // Foto-fotonya ditandai bulan per-FOTO (Upload.periodMonth) + satu periode utama.
  usesPeriodComparison Boolean       @default(false)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  metrics    SectionMetric[]
  uploads    Upload[]
  kbVersions KbVersion[]
  insights   Insight[]

  @@unique([platform, name])
}

enum MetricType {
  number
  currency
  percent
  ratio
}

model SectionMetric {
  id        String     @id @default(cuid())
  sectionId String
  key       String
  label     String
  type      MetricType @default(number)
  required  Boolean    @default(false)

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

model KbVersion {
  id        String   @id @default(cuid())
  sectionId String
  version   Int
  content   String
  createdAt DateTime @default(now())

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  // Audit M8: cegah dua baris versi sama saat generate insight bersamaan (race).
  @@unique([sectionId, version])
}

enum ReportStatus {
  draft
  processing
  done
  // Audit P5 (Jul 2026): report transisi ke sini saat PPT-nya PERTAMA kali diunduh.
  downloaded
}

model Report {
  id           String       @id @default(cuid())
  reportPeriod String
  platforms    Platform[]
  status       ReportStatus @default(draft)
  createdById  String
  createdAt    DateTime     @default(now())

  createdBy       User             @relation(fields: [createdById], references: [id])
  uploads         Upload[]
  flags           Flag[]
  insights        Insight[]
  conclusions     Conclusion[]
  recommendations Recommendation[]
}

// Fase A (gaya agency, Jul 2026) — "Rekomendasi & Action Plan" per (report, platform).
// DIKETIK USER MANUAL, bukan AI: teks bebas apa adanya (baris baru dipertahankan),
// TANPA bold otomatis, TANPA diproses model. Kosong = slide rekomendasi dilewati.
model Recommendation {
  id        String   @id @default(cuid())
  reportId  String
  platform  Platform
  content   String
  updatedAt DateTime @updatedAt

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, platform])
}

model Upload {
  id              String   @id @default(cuid())
  reportId        String
  platform        Platform
  sectionId       String
  imageUrl        String
  labelConfirmed  Boolean  @default(false)
  // Tahap 6b — HANYA untuk section ber-perbandingan-periode (selain itu null/false):
  // periodMonth kanonik "YYYY-MM" (urut kronologis = urut string; label "Juni 2026"
  // hanya di render — lib/period.ts). isPrimaryPeriod ditandai EKSPLISIT user (tidak
  // pernah otomatis), maks SATU per (report, section) — ditegakkan server.
  periodMonth     String?
  isPrimaryPeriod Boolean  @default(false)
  createdAt       DateTime @default(now())
  // Audit P2 (Jul 2026): jejak waktu perubahan data (tambah/ganti bulan/label) untuk
  // mendeteksi insight yang basi setelah data berubah. Baris lama di-backfill epoch.
  updatedAt       DateTime @updatedAt

  report      Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)
  section     Section      @relation(fields: [sectionId], references: [id])
  extractions Extraction[]

  // Audit M7: satu bulan = satu foto per (report, section). periodMonth NULL (section
  // non-perbandingan) TIDAK bertabrakan — Postgres perlakukan NULL sebagai distinct,
  // jadi ">1 foto = sumber terpisah" tetap boleh. Menegakkan aturan di level DB (race-safe).
  @@unique([reportId, sectionId, periodMonth])
}

enum ExtractionStatus {
  ok
  missing
  low_confidence
}

model Extraction {
  id                String           @id @default(cuid())
  uploadId          String
  key               String
  value             Float?
  rawText           String?
  confidence        Float            @default(0)
  status            ExtractionStatus @default(ok)
  // Tahap 5: true kalau user sudah konfirmasi/koreksi manual angka ini.
  // rawText & confidence asli TIDAK ditimpa (provenance OCR tetap utuh).
  manuallyConfirmed Boolean          @default(false)
  // Audit P2 (Jul 2026): jejak waktu perubahan angka (koreksi manual / ekstrak ulang)
  // untuk mendeteksi insight basi. Baris lama di-backfill epoch (belum berubah sejak).
  updatedAt         DateTime         @updatedAt

  upload Upload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
}

// Tahap 6a — insight Analyst per (report, section). Generate ulang = replace (upsert).
// points  = poin-poin insight (target 6 lunak, atap keras 8 — dipotong saat parsing),
//           menggantikan paragraf tunggal (keputusan Jul 2026).
// numbers = snapshot kosakata angka singkat (valueText) yang dikirim ke model saat generate —
//           dipakai renderer (PPT & web) untuk mem-bold angka metrik secara DETERMINISTIK
//           via pencocokan substring, TANPA penanda markdown dari LLM.
// kbVersion = versi KbVersion yang dipakai saat generate (pelacakan per DESIGN §Sistem Flag).
model Insight {
  id        String   @id @default(cuid())
  reportId  String
  sectionId String
  points    String[]
  numbers   String[]
  kbVersion Int
  generator String // "claude" | "stub"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  report    Report            @relation(fields: [reportId], references: [id], onDelete: Cascade)
  section   Section           @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  revisions InsightRevision[]

  @@unique([reportId, sectionId])
}

// Tahap 7b — jejak revisi Validator atas satu insight: TIDAK ada perubahan diam-diam.
// Validator memberi INSTRUKSI koreksi (bukan menulis ulang); Analyst yang merevisi dengan
// bahan angka SAMA dari Extraction (angka tak boleh berubah). Maks 1 putaran per section
// per run; resolved=false = cek ulang masih menemukan masalah → ter-escalate (ada Flag).
// Generate ulang insight manual menghapus jejak lama (jejak menempel pada generasi itu).
model InsightRevision {
  id           String   @id @default(cuid())
  insightId    String
  pointsBefore String[]
  pointsAfter  String[]
  reason       String // inkonsistensi yang ditemukan Validator (kontradiksi/tone + uraian)
  instruction  String // instruksi koreksi Validator yang dieksekusi Analyst
  resolved     Boolean
  createdAt    DateTime @default(now())

  insight Insight @relation(fields: [insightId], references: [id], onDelete: Cascade)
}

// Tahap 7a — kesimpulan Validator per (report, platform). Generate ulang = replace (upsert).
// Tabel SENDIRI (bukan Insight + penanda): identitasnya beda — Insight unik per
// (report, section), kesimpulan unik per (report, platform) — dan query Insight lama
// tak perlu mengecualikan apa pun. Kesimpulan TIDAK pernah gabungan lintas-platform
// (DESIGN Prinsip #4 & §Validator & Kesimpulan).
// points/numbers = mekanisme sama dengan Insight: poin (target 6 lunak, atap keras 8) +
// kosakata angka singkat untuk bold deterministik — numbers = union Insight.numbers
// semua section platform ini saat generate.
model Conclusion {
  id        String   @id @default(cuid())
  reportId  String
  platform  Platform
  points    String[]
  numbers   String[]
  generator String // "claude" | "stub"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, platform])
}

// Tahap 7a — dua KB Validator (DESIGN §Validator & Kesimpulan), satu baris per platform:
// kbGeneral = KB general/merangkai; kbConclusion = KB kesimpulan. Diisi founder via
// /dashboard/validator-kb; kosong = sah (prompt memakai penilaian umum).
// Versioning à la KbVersion DITUNDA sampai sistem flag (7b/9) — lihat backlog DESIGN.
model ValidatorKb {
  id           String   @id @default(cuid())
  platform     Platform @unique
  kbGeneral    String   @default("")
  kbConclusion String   @default("")
  updatedAt    DateTime @updatedAt
}

// Tahap 10 — tema global (Cara B): SATU tema aktif (baris pertama), diubah founder via
// /dashboard/theme, dipakai SEMUA report saat generate PPT (termasuk report lama —
// disengaja: PPT dirakit on-the-fly dengan tema aktif). Warna = hex 6 digit TANPA "#"
// (format pptxgenjs). Belum ada baris → default netral dipakai (tanpa error).
model Theme {
  id               String   @id @default(cuid())
  primaryColor     String   @default("111111") // warna utama brand (default hitam gaya agency, Fase B)
  secondaryColor   String   @default("6B7280") // pendukung: kicker, caption, footer, garis pemisah
  accentColor      String   @default("2563EB") // aksen dasar: bar judul, garis, panel insight
  headingFont      String   @default("Calibri")
  bodyFont         String   @default("Calibri")
  logoKey          String? // key storage (lib/storage.ts); null = tanpa logo
  accentOverride   Boolean  @default(false) // ON -> aksen per platform dipakai, bukan aksen dasar
  accentShopee     String   @default("EE4D2D")
  accentTiktok     String   @default("111827")
  // Fase A (gaya agency) — kontak slide Thank You; kosong = bagian itu tak ditampilkan.
  contactEmail     String   @default("officialgrowlab.id@gmail.com")
  contactWebsite   String   @default("www.growlab.id")
  contactInstagram String   @default("@growlab.id")
  updatedAt        DateTime @updatedAt
}

enum FlagSeverity {
  info
  tinggi
}

model Flag {
  id        String       @id @default(cuid())
  reportId  String
  platform  Platform
  section   String
  type      String
  severity  FlagSeverity @default(info)
  note      String
  createdAt DateTime     @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
}
