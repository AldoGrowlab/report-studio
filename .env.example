# Report Studio — daftar env (NAMA saja, isi nilai di .env lokal / dashboard Railway).
# JANGAN commit .env asli (sudah di-.gitignore). K1-K3: di produksi env yang kurang
# GAGAL KERAS (disengaja) — semua di bawah wajib terisi saat NODE_ENV=production.

# Postgres (Railway) — connection string lengkap
DATABASE_URL=

# Rahasia tanda tangan cookie sesi (HMAC). Produksi: string acak kuat, BUKAN nilai dev.
# Generate: openssl rand -hex 32
AUTH_SECRET=

# Claude (Extractor/Analyst/Validator). Tanpa ini di produksi = gagal keras (bukan stub).
ANTHROPIC_API_KEY=

# Cloudflare R2 (storage foto, S3-compatible). Tanpa 4-4nya lengkap di produksi = gagal keras
# (bukan fallback disk sementara).
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Seed akun founder (prisma/seed.ts). WAJIB saat menjalankan seed — tanpa ini seed GAGAL
# KERAS, bukan memakai password bawaan. Minimal 12 karakter.
# Generate: openssl rand -base64 24
SEED_ADMIN_PASSWORD=
# Opsional; default ke email founder yang sudah ada.
SEED_ADMIN_EMAIL=

# Model tier hemat untuk peran NON-ANGKA (opsional — ada default aman di kode).
# Extractor/Analyst/Validator TIDAK memakai ini: mereka menyentuh angka dan dikunci
# ke claude-opus-4-8 di kode supaya presisi tak bisa diturunkan lewat env tanpa sengaja.
MERGE_SUGGEST_MODEL=
PERIOD_DETECT_MODEL=

# Diset otomatis oleh Railway saat deploy; set eksplisit "production" untuk memastikan.
NODE_ENV=
